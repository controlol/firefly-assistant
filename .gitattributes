# Normalize line endings: store all text files with LF in the repository,
# regardless of the contributor's OS. Avoids CRLF/LF diff churn on Windows.
* text=auto eol=lf

# Explicit text types
*.py    text
*.md    text
*.toml  text
*.json  text
*.txt   text
*.cfg   text
*.ini   text

# Binary types — never apply line-ending conversion
*.pdf   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.tar   binary
*.onnx  binary
*.xlsx  binary
