# Copy to .env and fill in. Loaded by pydantic-settings.

# --- IMAP mailbox to ingest invoices/receipts from ---
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USERNAME=invoices@example.com
IMAP_PASSWORD=app-specific-password
IMAP_MAILBOX=INBOX
# Custom IMAP keyword set once an invoice is attached; processed mail is skipped, never deleted.
IMAP_PROCESSED_KEYWORD=FireflyProcessed

# --- Firefly III ---
FIREFLY_BASE_URL=https://firefly.example.com
FIREFLY_TOKEN=your-personal-access-token
FIREFLY_VERIFY_TLS=true

# --- Matching behaviour ---
MATCH_DATE_WINDOW_DAYS=30
MATCH_AMOUNT_TOLERANCE=0.02
MATCH_AUTO_ATTACH_THRESHOLD=0.8
MATCH_NEEDS_REVIEW_TAG=needs-review
MATCH_PROCESSED_TAG=firefly-bot

# --- Bank statement import (firefly-bot import --camt ...) ---
# Account holder name: counterparties with this name are imported as transfers between your
# own accounts (e.g. savings) instead of income/expense.
BANK_OWNER_NAME=
# Optional extra own-account IBANs if name detection is not enough, e.g. ["NL00BANK9876543210"]
BANK_OWN_IBANS=[]
BANK_ACCOUNT_NAME=Betaalrekening

# --- Misc ---
REPORT_DIR=./reports
OCR_USE_GPU=false
